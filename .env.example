# ============================================================================
# Sentinel-911 Environment Variables
# ============================================================================
# Copy this file to .env.local (frontend) and server_end/.env (backend)

# ── Required ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Backend (server_end/.env) ─────────────────────────────────────────────
AES_SECRET=d3377d4ddc5d3f33c6a9100d28993874
GCP_PROJECT_ID=your_gcp_project_id

# ── Frontend (.env.local) ────────────────────────────────────────────────
# For local development, leave blank (defaults to http://localhost:8000)
# For production, set to your Cloud Run URL:
# VITE_BACKEND_URL=https://sentinel911-backend-xxxxx-uc.a.run.app
VITE_BACKEND_URL=
